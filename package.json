{
  "name": "legendas-pro",
  "version": "1.0.0",
  "description": "Sistema profissional de transcrição, edição, tradução, exportação e renderização de legendas para vídeo",
  "main": "backend/src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "init:db": "node backend/src/database/init.js",
    "worker": "node backend/src/workers/transcricao.worker.js",
    "lint": "eslint backend/src/**/*.js"
  },
  "keywords": [
    "legendas",
    "transcrição",
    "whisper",
    "vídeo",
    "offline",
    "legendagem"
  ],
  "author": "Legendas Pro Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "bull": "^4.16.5",
    "bullmq": "^5.34.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "socket.io": "^4.7.2",
    "uuid": "^14.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.2.5"
  },
  "overrides": {
    "bull": {
      "uuid": "^11.1.1"
    }
  }
}
