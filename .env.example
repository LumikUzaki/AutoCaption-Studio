# Porta do servidor HTTP
PORT=3000

# Ambiente (development ou production)
NODE_ENV=development

# Caminho para o banco de dados SQLite
DATABASE_PATH=./database/legendas_pro.db

# Diretório de uploads
UPLOAD_DIR=./backend/uploads

# Diretório de outputs
OUTPUT_DIR=./backend/outputs

# Caminho para o interpretador Python
PYTHON_PATH=python3

# Diretório dos scripts Python
PYTHON_DIR=./python

# Tamanho máximo de upload (em bytes) - padrão 2GB
MAX_FILE_SIZE=2147483648

# Engines disponíveis (separadas por vírgula)
AVAILABLE_ENGINES=faster-whisper,stable-ts,whisperx

# Modelo padrão do Whisper
DEFAULT_MODEL=base

# Dispositivo padrão (cuda ou cpu)
DEFAULT_DEVICE=cuda
