# ============================
# Servidor
# ============================
PORT=3000
UPLOAD_MAX_SIZE_GB=10
NODE_ENV=development
LOG_LEVEL=info

# ============================
# Caminhos dos binários
# ============================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
PYTHON_PATH=python

# ============================
# Diretórios do projeto
# ============================
UPLOAD_DIR=./backend/uploads
TEMP_DIR=./backend/temp
OUTPUT_DIR=./backend/output
LOG_DIR=./backend/logs

# ============================
# Redis / Fila (Bull)
# ============================
REDIS_MODE=memory
REDIS_URL=redis://127.0.0.1:6379
QUEUE_CONCURRENCY=1
QUEUE_MAX_ATTEMPTS=2
JOB_TIMEOUT_MS=1800000

# ============================
# Configurações padrão gerais
# ============================
DEFAULT_ENGINE=stable-ts
DEFAULT_MODEL=medium
DEFAULT_LANGUAGE=auto
DEFAULT_DEVICE=cuda
DEFAULT_COMPUTE_TYPE=float16

# ============================
# Faster-Whisper (defaults)
# ============================
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_BEST_OF=5

# ============================
# Stable-TS (defaults)
# ============================
STABLE_TS_DEVICE=cuda
STABLE_TS_COMPUTE_TYPE=float16
STABLE_TS_REGROUP=true
STABLE_TS_SUPPRESS_SILENCE=true
STABLE_TS_VAD=true

# ============================
# WhisperX (defaults)
# ============================
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_ALIGN_MODEL=WAV2VEC2_ASR_LARGE_LV60K_960H
WHISPERX_BATCH_SIZE=16
WHISPERX_DIARIZATION=false
WHISPERX_HF_TOKEN=

# ============================
# Socket.IO / Progresso
# ============================
SOCKET_CORS_ORIGIN=*
PROGRESS_EMIT_INTERVAL_MS=500

# ============================
# Limpeza automática
# ============================
TEMP_FILE_TTL_HOURS=24
AUTO_CLEANUP_ENABLED=true